{
    "name": "dertunnel",
    "version": "0.7.14",
    "description": "A ngrok-style tunnel client/server",
    "main": "index.js",
    "scripts": {
        "server": "node -r esbuild-register src/server/index.ts",
        "client": "node -r esbuild-register src/client/cli.ts",
        "token": "node -r esbuild-register src/create-token.ts",
        "test": "jest",
        "compile": "tsc --noemit",
        "licenses": "node ./licenses.js ./dist",
        "lint": "eslint src/ --ext .ts",
        "ci": "npm run compile && npm run lint && npm run test && npm run package",
        "bundle": "npm run licenses && npm run server:bundle && npm run client:bundle && npm run ui:bundle && npm run client:lib",
        "server:bundle": "esbuild --target=es2022 --bundle --minify --platform=node --metafile=./dist/dertunnel-server-meta.json --outfile=./dist/dertunnel-server.js ./src/server/index.ts",
        "client:bundle": "esbuild --target=es2022 --bundle --minify --platform=node --metafile=./dist/dertunnel-client-meta.json --banner:js=\"#!/usr/bin/env node\" --outfile=./dist/dertunnel-client.js ./src/client/cli.ts",
        "client:lib": "esbuild --target=es2022 --bundle --minify --platform=node --outfile=./packages/dertunnel/index.js ./src/client/client.ts && copyfiles -f ./dist/dertunnel-client.js packages/dertunnel && cd packages/dertunnel && npm pack --pack-destination ../../dist && cd ../..",
        "client:package": "pkg --public --no-bytecode -c ./pkg.client.json ./dist/dertunnel-client.js",
        "server:package": "pkg --public --no-bytecode -c ./pkg.server.json ./dist/dertunnel-server.js",
        "package": "npm run bundle && npm run server:package && npm run client:package",
        "ui:bundle": "esbuild --target=es2022 --bundle --minify --sourcemap --outfile=./public/bundle.js ./src/ui/index.tsx",
        "ui:watch": "esbuild --target=es2022 --watch --bundle --sourcemap --outfile=./public/bundle.js ./src/ui/index.tsx"
    },
    "keywords": [
        "tunnel"
    ],
    "author": "faulpeltz",
    "license": "MIT",
    "devDependencies": {
        "@types/express": "5.0.6",
        "@types/jest": "30.0.0",
        "@types/node": "22.19.19",
        "@types/prompts": "~2.4.9",
        "@typescript-eslint/eslint-plugin": "8.60.0",
        "@typescript-eslint/parser": "8.60.0",
        "@yao-pkg/pkg": "6.19.0",
        "copyfiles": "2.4.1",
        "esbuild": "0.28.1",
        "esbuild-register": "3.6.0",
        "eslint": "8.57.1",
        "eslint-plugin-jest": "29.15.2",
        "jest": "30.4.2",
        "license-compliance": "3.0.1",
        "typescript": "6.0.3"
    },
    "dependencies": {
        "acme-client": "5.4.0",
        "chalk": "5.6.2",
        "commander": "14.0.3",
        "conf": "15.1.0",
        "dns2": "2.4.0",
        "express": "5.2.1",
        "lru-cache": "11.5.0",
        "nanoid": "5.1.11",
        "prompts": "2.4.2",
        "rate-limiter-flexible": "11.1.0"
    },
    "overrides": {
        "@istanbuljs/load-nyc-config": {
            "js-yaml": "4.2.0"
        }
    }
}
